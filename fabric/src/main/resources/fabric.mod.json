{
  "schemaVersion": 1,
  "id": "exphardcore",
  "version": "${version_prefix}-fabric",
  "name": "${mod_name}",
  "description": "Expeditionary Hardcore.",
  "authors": [
    "Filloax"
  ],
  "contact": {
    "homepage": "https://github.com/filloax/expeditionary-hardcore",
    "issues": "https://github.com/filloax/expeditionary-hardcore/issues",
    "source": "https://github.com/filloax/expeditionary-hardcore"
  },
  "license": "MIT",
  "icon": "assets/exphardcore/icon.png",
  "environment": "*",
  "accessWidener": "exphardcore.accesswidener",
  "mixins": [
    "exphardcore.mixins.json",
    "exphardcore-fabric.mixins.json"
  ],
  "entrypoints": {
    "main": [
      {
        "value": "com.filloax.exphardcore.ExpeditionaryHardcoreFabric",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "com.filloax.exphardcore.ExpeditionaryHardcoreFabricClient",
        "adapter": "kotlin"
      }
    ],
    "fabric-datagen": [
      {
        "value": "com.filloax.exphardcore.data.ExpeditionaryHardcoreDataGenerator",
        "adapter": "kotlin"
      }
    ]
  },
  "depends": {
    "filloaxlib": ">=${filloaxlib_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "resourcefulconfig": ">=${rconfig_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fapi_version}",
    "minecraft": "${fabric_minecraft_version_range}"
  },
  "suggests": {
    "apibalego": ">=${apibalego_version}"
  }
}
